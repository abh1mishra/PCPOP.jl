zaz=Dict{Tuple{Int64,Int64},Monomial{Variable}}()
iops=collect(enumerate(monomials(cb,2)))
for (i, x) in iops
               for (j, y) in iops[i:end]
                   # println(i,"--",j)
                   p=prod([x',y])
                   p=p<=p' ? p : p'
                     kak[(i,j)]=p
               end
           end

sas=Vector{Tuple{Monomial{Variable},Monomial{Variable},Monomial{Variable},Monomial{Variable}}}()
for (i,j) in zaz
    if kak[i]!=j
        push!(sas,(mons[i[1]],mons[i[2]],kak[i],j))
    end
end